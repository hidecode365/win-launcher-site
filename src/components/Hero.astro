---
import CopyCommandButton from './CopyCommandButton';
import DownloadDropdown from './DownloadDropdown';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="hero">
  <div class="container hero-inner">
    <img class="logo" src={`${base}app-icon.png`} width="64" height="64" alt="WinLauncher" />
    <p class="wordmark">WinLauncher</p>
    <h1>すべてのアプリへ最短距離</h1>
    <p class="subtext">無料・オープンソース・サーバーレス。Windows 11のためのキーボードランチャー</p>

    <div class="hotkey" aria-label="ホットキー Alt プラス Space">
      <span class="keycap">Alt</span>
      <span class="plus">+</span>
      <span class="keycap">Space</span>
    </div>

    <div class="cta-group">
      <CopyCommandButton
        client:load
        command="winget install hidecode365.WinLauncher"
        label="winget install コマンドをコピー"
        variant="primary"
      />
      <DownloadDropdown client:load />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 96px;
    padding-bottom: 96px;
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, var(--color-bg) 100%);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .logo {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    margin-bottom: 8px;
  }

  .wordmark {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-accent);
  }

  h1 {
    font-size: clamp(1.35rem, 6vw, 3rem);
    font-weight: 800;
    white-space: nowrap;
  }

  .subtext {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 44ch;
    margin-bottom: 12px;
  }

  .hotkey {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0 32px;
  }

  .keycap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 84px;
    padding: 14px 20px;
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 3px 0 var(--color-border);
  }

  .plus {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .keycap {
      min-width: 64px;
      padding: 10px 14px;
      font-size: 1.1rem;
    }
  }
</style>
