---
import FeatureGrid from './FeatureGrid';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const featureData = [
  {
    icon: '🔍',
    title: 'アプリ・ファイル・フォルダ検索',
    desc: 'ホットキー一つで、あらゆるアプリ・ファイル・フォルダへ即座にアクセス。',
    screenshot: 'screenshot-search.png',
  },
  {
    icon: '🖼️',
    title: 'OCR検索',
    desc: '画面上のテキストを画像から抽出し、そのまま検索対象にできます。',
    screenshot: 'screenshot-ocr.png',
  },
  {
    icon: '/',
    title: '明示プレフィックス方式',
    desc: '`/`コマンドでシステム操作・クリップボード履歴などを素早く呼び出せます。',
    screenshot: 'screenshot-clipboard.png',
  },
  {
    icon: '⚡',
    title: '自動更新・軽量動作・完全無料',
    desc: 'バックグラウンドで静かに動作し、常に最新の状態を保てます。',
    screenshot: 'screenshot-settings.png',
  },
];

const features = featureData.map((f) => ({
  icon: f.icon,
  title: f.title,
  desc: f.desc,
  src: `${base}screenshots/${f.screenshot}`,
}));
---

<section class="features">
  <div class="container">
    <h2 class="section-title">主要機能</h2>
    <FeatureGrid client:load features={features} />
  </div>
</section>
