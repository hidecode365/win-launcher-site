---
const notes = [
  {
    icon: '🖥️',
    title: '動作環境',
    desc: 'Windows 11 (x64)',
  },
  {
    icon: '📦',
    title: 'インストーラーの選び方',
    desc: '「.exe」は通常インストール向け(個人利用・推奨)。「.msi」は企業のサイレントインストールやMDM配布向けです。',
  },
  {
    icon: '🔄',
    title: '自動更新について',
    desc: 'インストール後はバックグラウンドで自動的に最新版へ更新されます。',
  },
  {
    icon: '🔓',
    title: 'オープンソース・サーバーレス',
    desc: 'ソースコードは公開されており、外部サーバーへ通信しない設計のため安心してご利用いただけます。',
  },
  {
    icon: '🛡️',
    title: '初回インストール時の警告について',
    desc: 'コード署名を行っていないため、インストール時にWindowsの警告が表示されますが、そのまま進めていただいて問題ありません。',
  },
];
---

<section class="install-info">
  <div class="container">
    <h2 class="section-title">補足情報</h2>
    <div class="info-grid">
      {
        notes.map((note) => (
          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              {note.icon}
            </div>
            <h3>{note.title}</h3>
            <p>{note.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 24px;
    text-align: left;
  }

  .info-card:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  .info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin-bottom: 12px;
    font-size: 1.3rem;
    background: var(--color-accent-soft);
    border-radius: 10px;
  }

  .info-card h3 {
    font-size: 1rem;
    margin: 0 0 8px;
  }

  .info-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 640px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
